# Google 스프레드시트 ID (URL /d/ 와 /edit 사이)
# 예: https://docs.google.com/spreadsheets/d/11XbdqDSIgjcuYk69TnFjxAuKN4FCnxdLD3G9si_dIjE/edit?gid=0
SPREADSHEET_ID=

# URL 주소창 #gid=0 과 동일하게 맞출 것 (첫 번째 탭이면 0)
SPELLING_GID=0

# 주의(caution) 탭 gid — 예: caution_rules 시트 URL의 gid=
# CAUTION_GID=240056247

# 본용언+보조용언(일관성) 탭 — 기본 bon-bojo
# BON_BOJO_SHEET=bon-bojo
# BON_BOJO_GID=

# SPELLING_GID 대신 탭 이름으로 받을 때만:
# SPELLING_SHEET=spelling_rules

# 목차 · 본문 일치 검수 — 프로덕션 빌드 기본 끔. 로컬 npm run dev 는 항상 켜짐.
# preview 빌드에서 켜려면: VITE_FEATURE_TOC_BODY_CHECK=true
# VITE_FEATURE_TOC_BODY_CHECK=true

# 베타 분석 (PostHog) — 없으면 수집 안 함. project-docs/analytics-beta.md
# VITE_PUBLIC_POSTHOG_KEY=phc_…
# VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Google 회원가입/로그인 (Firebase Auth) — Vercel에도 동일 키 등록
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=

# 피드백 — Google Form (연결·검증: docs/feedback-form.md)
# 변경 후 npm run dev 재시작.

# 공유용 짧은 링크 (선택) — 모달에서 「파일 첨부하기(구글 폼으로 작성)」
# VITE_FEEDBACK_FORM_VIEW_URL=https://forms.gle/f6FpybKZHC5yAR817

# POST 제출 — viewform URL의 viewform → formResponse
# VITE_FEEDBACK_FORM_ACTION_URL=https://docs.google.com/forms/d/e/…/formResponse

# 방식 A — 단답·장문 2필드 (분류 / 내용)
# VITE_FEEDBACK_FORM_ENTRY_TYPE=entry.1234567890
# VITE_FEEDBACK_FORM_ENTRY_MESSAGE=entry.0987654321

# 방식 B — 체크박스 2질문 (불편한 점 / 편한 점, 기타 응답)
# VITE_FEEDBACK_FORM_ENTRY_INCONVENIENT=entry.2074090186
# VITE_FEEDBACK_FORM_ENTRY_CONVENIENT=entry.944707313
