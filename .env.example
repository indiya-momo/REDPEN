# Google 스프레드시트 ID (URL /d/ 와 /edit 사이)
# 예: https://docs.google.com/spreadsheets/d/11XbdqDSIgjcuYk69TnFjxAuKN4FCnxdLD3G9si_dIjE/edit?gid=0
SPREADSHEET_ID=

# URL 주소창 #gid=0 과 동일하게 맞출 것 (첫 번째 탭이면 0)
SPELLING_GID=0

# 주의(caution) 탭 gid — 예: caution_rules 시트 URL의 gid=
# CAUTION_GID=240056247

# 본용언+보조용언(일관성) 탭 — 기본 bon-bojo
# BON_BOJO_SHEET=bon-bojo
# BON_BOJO_GID=

# SPELLING_GID 대신 탭 이름으로 받을 때만:
# SPELLING_SHEET=spelling_rules

# 작업 말풍선 — localhost dev는 기본 pin(확인해도 안 숨김·HMR 후 단계 유지). 끄려면 false
# VITE_WORK_GUIDE_PIN_ALL=false

# 로컬 dev 포트 — 기본 5173. 다른 포트는 worktree별 .env.local (이 PC worktree는 5173 고정 권장)
# DEV_PORT=5180
# 전체 pin 강제: true 또는 ?workGuidePin=1 · 끄기 ?workGuidePin=0
# VITE_WORK_GUIDE_PIN_ALL=true

# 목차 · 본문 일치 검수 — npm run dev 에서만 기본 켜짐. preview/배포에서 켜려면:
# VITE_FEATURE_TOC_BODY_CHECK=true

# 검수 결과 엑셀 다운로드 — dev·배포 기본 켜짐. 끄려면:
# VITE_FEATURE_SPELLING_EXPORT=false

# 외래어 표기 변환 — 둘러보기·로그인 모두 기본 켜짐. 끄려면:
# VITE_FEATURE_LOANWORD_CONVERTER=false

# 국립국어원 어문 규범 Open API (한글·오표기·원어 용례) — https://korean.go.kr/kornorms/main/openAPI.do
# 발급 키를 URL Encode 없이 그대로. 로컬: .env.local + npm run dev 재시작. 커밋 금지.
# Vercel: Settings → Environment Variables 에 아래 중 하나 등록 후 Redeploy
#   KORNORMS_SERVICE_KEY=…   (권장, 서버 전용 — api/kornorms 프록시가 사용)
#   또는 VITE_KORNORMS_SERVICE_KEY=…  (로컬과 동일 이름도 서버에서 읽음)
# VITE_KORNORMS_SERVICE_KEY=
# 베타 분석 (PostHog) — 없으면 수집 안 함. project-docs/analytics-beta.md
# 로컬: VITE_PUBLIC_POSTHOG_*  |  Vercel Marketplace 연동 시 NEXT_PUBLIC_POSTHOG_* 자동 주입
# VITE_PUBLIC_POSTHOG_KEY=phc_…
# VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# (Vercel만) NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN / NEXT_PUBLIC_POSTHOG_HOST — project-docs/vercel-posthog.md
# 대시보드 자동 생성(로컬만, git 제외): POSTHOG_PERSONAL_API_KEY=phx_… → npm run posthog:setup-beta

# Google 회원가입/로그인 (Firebase Auth) — Vercel에도 동일 키 등록
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=

# 오픈베타 1일 1회 검수 한도(Firestore). 전역 끄려면 false
# VITE_BETA_DAILY_QUOTA=false
# npm run dev + localhost — 배포와 동일하게 한도 적용(기본). 로컬만 한도 끄려면:
# VITE_BETA_QUOTA_RELAX_LOCAL=true
# 배포·preview 한도 면제(쉼표 구분) — Google 이메일 또는 Firebase uid
# VITE_BETA_QUOTA_ADMIN_EMAILS=your@gmail.com
# VITE_BETA_QUOTA_ADMIN_UIDS=
# Cloud Functions 유료 등록도 동일 값 필요 (functions/.env 또는 Firebase Console):
# BETA_QUOTA_ADMIN_EMAILS=… / BETA_QUOTA_ADMIN_UIDS=…

# 피드백 — Google Form (연결·검증: docs/feedback-form.md)
# 변경 후 npm run dev 재시작.

# Google Form (베타 기본) — 비우면 forms.gle/XGxKjjyWZiYDnqrm8 사용
# VITE_FEEDBACK_FORM_VIEW_URL=https://forms.gle/XGxKjjyWZiYDnqrm8

# 제출 완료 시 혜택 — Form에 숨은 uid 필드 + 제출 후 리다이렉트 URL 설정 필요
# Form 설정 → 제출 후 → 링크: 비우면 앱 origin/?feedbackSubmitted=1 (getFeedbackFormReturnUrl)
# VITE_FEEDBACK_FORM_RETURN_URL=https://indiya.vercel.app/?feedbackSubmitted=1
# uid prefill (forms.gle 불가 — docs.google.com …/viewform 권장)
# VITE_FEEDBACK_FORM_PREFILL_VIEW_URL=https://docs.google.com/forms/d/e/…/viewform
# VITE_FEEDBACK_FORM_ENTRY_UID=entry.1234567890

# POST 제출 — viewform URL의 viewform → formResponse
# VITE_FEEDBACK_FORM_ACTION_URL=https://docs.google.com/forms/d/e/…/formResponse

# 방식 A — 단답·장문 2필드 (분류 / 내용)
# VITE_FEEDBACK_FORM_ENTRY_TYPE=entry.1234567890
# VITE_FEEDBACK_FORM_ENTRY_MESSAGE=entry.0987654321

# 방식 B — 체크박스 2질문 (불편한 점 / 편한 점, 기타 응답)
# VITE_FEEDBACK_FORM_ENTRY_INCONVENIENT=entry.2074090186
# VITE_FEEDBACK_FORM_ENTRY_CONVENIENT=entry.944707313
