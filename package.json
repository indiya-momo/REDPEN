{
  "name": "pdf-publish-proofread",
  "private": true,
  "version": "0.902",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite --host --open",
    "start:win": "powershell -ExecutionPolicy Bypass -File scripts/Start-Dev.ps1",
    "open:browser": "powershell -ExecutionPolicy Bypass -File scripts/Fix-Browser-Access.ps1",
    "open:dev": "powershell -ExecutionPolicy Bypass -File scripts/Open-Dev-Browser.ps1",
    "build": "vite build",
    "test": "vitest run && npm run validate-data",
    "test:watch": "vitest",
    "validate-data": "node scripts/validate-data-json.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "preview": "vite preview --host --open",
    "sync-spelling": "node scripts/sync-spelling.mjs",
    "sync-caution": "node scripts/sync-caution.mjs",
    "sync-bon-bojo": "node scripts/sync-bon-bojo.mjs",
    "sync": "npm run sync-spelling && npm run sync-caution && npm run sync-bon-bojo",
    "optimize-momo-room": "node scripts/optimize-momo-room-library.mjs && node scripts/generate-momo-room-window-front.mjs",
    "trim:badges": "node scripts/trim-welcome-badges.mjs",
    "firebase:firestore:deploy": "npx --yes firebase-tools@14.2.1 deploy --only firestore:rules --project indiya-757ba",
    "firebase:firestore:setup": "powershell -ExecutionPolicy Bypass -File scripts/Deploy-FirestoreBetaQuota.ps1",
    "posthog:setup-beta": "node scripts/posthog-beta-dashboard-setup.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "firebase": "^12.14.0",
    "lucide-react": "^0.511.0",
    "pdfjs-dist": "5.2.133",
    "posthog-js": "^1.376.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "vite": "^6.3.5",
    "vitest": "^4.1.7"
  }
}
